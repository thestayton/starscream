---
import Base from '../layouts/Base.astro';
---

<Base>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow">⭐ Hey Bodhi! ⭐</p>
      <div class="hero-robot">🤖</div>
      <h1 class="hero-title">STARSCREAM!</h1>
      <p class="hero-sub">The coolest <span>Decepticon jet fighter</span> in the universe!</p>
      <div class="hero-badges">
        <span class="badge">✈️ Transforms into a jet</span>
        <span class="badge">⚡ Shoots laser rays</span>
        <span class="badge">🌌 Flies in space</span>
      </div>
      <p class="scroll-hint">Scroll down to learn more ↓</p>
    </div>
  </section>

  <!-- WHO IS STARSCREAM -->
  <section id="who" class="content-section who-section">
    <div class="container">
      <h2 class="section-heading">Who is Starscream?</h2>
      <p class="section-sub">Get ready — this robot is SO cool!</p>
      <div class="who-card">
        <div class="who-icon">🦅</div>
        <p>
          Starscream is a <span class="highlight-purple">Decepticon</span> — a robot on the
          <span class="highlight-purple">sneaky side</span>! He is
          <span class="highlight-purple">silver and purple</span> and VERY fast.
          He wants to be the most <span class="highlight-purple">powerful robot ever</span>
          and thinks he is <span class="highlight-red">the best at EVERYTHING!</span>
          He is always yelling — that's why his name is
          <span class="highlight-purple">STARSCREAM!</span> 🌟
        </p>
      </div>
    </div>
  </section>

  <!-- TRANSFORMATION -->
  <section id="transform" class="content-section transform-section">
    <div class="container">
      <h2 class="section-heading">He turns into a jet!</h2>
      <p class="section-sub">One second he's a robot... then WHOOOOSH!</p>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-icon">🤖</div>
          <h3>Robot!</h3>
          <p>Tall, strong, and ready to fight</p>
        </div>
        <div class="step-card step-middle">
          <div class="step-icon">⚡</div>
          <h3>Transform!</h3>
          <p>He changes shape SUPER fast!</p>
        </div>
        <div class="step-card">
          <div class="step-icon">✈️</div>
          <h3>Jet!</h3>
          <p>ZOOM through the sky!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- POWERS -->
  <section id="powers" class="content-section powers-section">
    <div class="container">
      <h2 class="section-heading">Superpowers!</h2>
      <p class="section-sub">Starscream has SO many cool powers!</p>
      <div class="powers-grid">
        <div class="power-card">
          <div class="power-icon">🔥</div>
          <div>
            <h3>Null Rays</h3>
            <p>Laser beams from his arms that freeze robots in their tracks!</p>
          </div>
        </div>
        <div class="power-card">
          <div class="power-icon">🚀</div>
          <div>
            <h3>Super Speed</h3>
            <p>As a jet he goes faster than anything — even faster than sound!</p>
          </div>
        </div>
        <div class="power-card">
          <div class="power-icon">🌌</div>
          <div>
            <h3>Space Flight</h3>
            <p>He can fly all the way into outer space — past all the stars!</p>
          </div>
        </div>
        <div class="power-card">
          <div class="power-icon">🛡️</div>
          <div>
            <h3>Tough Armor</h3>
            <p>His body is made of super hard Cybertronian metal. Almost unbreakable!</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FUN FACTS -->
  <section id="facts" class="content-section facts-section">
    <div class="container">
      <h2 class="section-heading">Cool Facts!</h2>
      <p class="section-sub">Did you know these things about Starscream?</p>
      <div class="facts-list">
        <div class="fact-item">
          <span class="fact-num">1</span>
          <p>Starscream turns into an <span class="highlight-cyan">F-15 Eagle</span> — one of the fastest fighter jets ever built!</p>
        </div>
        <div class="fact-item">
          <span class="fact-num">2</span>
          <p>His colors are <span class="highlight-cyan">silver, purple, and red</span> — the most awesome robot colors!</p>
        </div>
        <div class="fact-item">
          <span class="fact-num">3</span>
          <p>He is always trying to <span class="highlight-cyan">become the leader</span> of all the Decepticons because he thinks he's the best!</p>
        </div>
        <div class="fact-item">
          <span class="fact-num">4</span>
          <p>Starscream has been in <span class="highlight-cyan">almost every Transformers show</span> since 1984 — that's a really long time!</p>
        </div>
        <div class="fact-item">
          <span class="fact-num">5</span>
          <p>Even though he's a bad guy, <span class="highlight-cyan">tons of kids love him</span> — because he's so exciting to watch!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="content-section mission-section">
    <div class="container">
      <h2 class="section-heading">Your Mission, Bodhi!</h2>
      <div class="mission-card">
        <p>
          You are now an <span class="highlight-gold">honorary Seeker</span> — just like Starscream's crew!<br /><br />
          Your job: <span class="highlight-gold">watch the skies</span>, know your Transformers,
          and <span class="highlight-gold">NEVER stop having fun!</span> ⚡🤖✈️
        </p>
      </div>
      <a
        href="https://www.youtube.com/results?search_query=starscream+transformers+cartoon"
        target="_blank"
        rel="noopener"
        class="watch-btn"
      >
        Watch Starscream! 🎬
      </a>
    </div>
  </section>

</Base>

<style>
  /* HERO */
  .hero {
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 0;
    background: radial-gradient(ellipse at top, #1a0533 0%, transparent 65%);
    text-align: center;
  }
  .eyebrow {
    font-family: 'Bangers', cursive;
    font-size: clamp(1.2rem, 4vw, 2rem);
    color: #fbbf24;
    letter-spacing: 0.1em;
    text-shadow: 0 0 20px rgba(251,191,36,0.5);
    margin-bottom: 0.75rem;
  }
  .hero-robot {
    font-size: clamp(5rem, 18vw, 9rem);
    line-height: 1;
    filter: drop-shadow(0 0 30px rgba(168,85,247,0.8));
    animation: float 3s ease-in-out infinite;
    margin: 0.75rem 0;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-18px) rotate(2deg); }
  }
  .hero-title {
    font-family: 'Bangers', cursive;
    font-size: clamp(4rem, 18vw, 8rem);
    line-height: 0.9;
    background: linear-gradient(135deg, #a855f7 0%, #ef4444 50%, #cbd5e1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0.05em;
    filter: drop-shadow(0 0 40px rgba(168,85,247,0.5));
    margin-bottom: 0.75rem;
  }
  .hero-sub {
    font-size: clamp(1rem, 3.5vw, 1.4rem);
    font-weight: 800;
    color: #cbd5e1;
    margin-bottom: 1.5rem;
  }
  .hero-sub span { color: #a855f7; }
  .hero-badges {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2rem;
  }
  .badge {
    background: rgba(124,58,237,0.25);
    border: 2px solid rgba(168,85,247,0.5);
    border-radius: 50px;
    padding: 0.4rem 1rem;
    font-size: 0.9rem;
    font-weight: 800;
    color: #a855f7;
  }
  .scroll-hint {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.3);
    font-weight: 700;
    animation: bounce 2s ease-in-out infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* SHARED SECTION STYLES */
  .content-section { padding: 4rem 0; }
  .section-heading {
    font-family: 'Bangers', cursive;
    font-size: clamp(2.5rem, 8vw, 4rem);
    letter-spacing: 0.05em;
    line-height: 1;
    margin-bottom: 0.5rem;
    text-align: center;
  }
  .section-sub {
    font-size: clamp(1rem, 3vw, 1.15rem);
    font-weight: 700;
    color: #cbd5e1;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  /* WHO */
  .who-section { background: radial-gradient(ellipse at center, rgba(124,58,237,0.08) 0%, transparent 70%); }
  .who-section .section-heading { color: #a855f7; }
  .who-card {
    background: rgba(255,255,255,0.04);
    border: 2px solid rgba(168,85,247,0.3);
    border-radius: 24px;
    padding: 2rem;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }
  .who-icon { font-size: 4rem; margin-bottom: 1rem; }
  .who-card p {
    font-size: clamp(1rem, 3vw, 1.25rem);
    font-weight: 800;
    line-height: 1.7;
  }

  /* TRANSFORM */
  .transform-section { background: radial-gradient(ellipse at center, rgba(239,68,68,0.06) 0%, transparent 70%); }
  .transform-section .section-heading { color: #ff6b6b; }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 680px;
    margin: 0 auto;
  }
  .step-card {
    background: rgba(255,255,255,0.04);
    border: 2px solid rgba(239,68,68,0.25);
    border-radius: 20px;
    padding: 1.5rem 1rem;
    text-align: center;
    transition: border-color 0.2s;
  }
  .step-card:hover { border-color: rgba(239,68,68,0.5); }
  .step-middle { border-color: rgba(239,68,68,0.5); }
  .step-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .step-card h3 {
    font-family: 'Bangers', cursive;
    font-size: 1.6rem;
    color: #ff6b6b;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .step-card p { font-size: 0.9rem; font-weight: 700; color: #cbd5e1; }

  /* POWERS */
  .powers-section { background: radial-gradient(ellipse at center, rgba(251,191,36,0.05) 0%, transparent 70%); }
  .powers-section .section-heading { color: #fbbf24; }
  .powers-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    max-width: 680px;
    margin: 0 auto;
  }
  .power-card {
    background: rgba(255,255,255,0.04);
    border: 2px solid rgba(251,191,36,0.25);
    border-radius: 20px;
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    transition: border-color 0.2s;
  }
  .power-card:hover { border-color: rgba(251,191,36,0.5); }
  .power-icon { font-size: 2.25rem; flex-shrink: 0; }
  .power-card h3 {
    font-family: 'Bangers', cursive;
    font-size: 1.5rem;
    color: #fbbf24;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .power-card p { font-size: 0.9rem; font-weight: 700; color: #cbd5e1; line-height: 1.5; }

  /* FACTS */
  .facts-section { background: radial-gradient(ellipse at center, rgba(100,200,255,0.05) 0%, transparent 70%); }
  .facts-section .section-heading { color: #67e8f9; }
  .facts-list {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .fact-item {
    background: rgba(255,255,255,0.04);
    border: 2px solid rgba(103,232,249,0.2);
    border-radius: 16px;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: border-color 0.2s;
  }
  .fact-item:hover { border-color: rgba(103,232,249,0.4); }
  .fact-num {
    font-family: 'Bangers', cursive;
    font-size: 2rem;
    color: #67e8f9;
    flex-shrink: 0;
    min-width: 2rem;
    text-align: center;
    line-height: 1;
  }
  .fact-item p { font-size: 1rem; font-weight: 800; line-height: 1.5; }

  /* MISSION */
  .mission-section {
    text-align: center;
    background: radial-gradient(ellipse at center, rgba(124,58,237,0.12) 0%, transparent 60%);
  }
  .mission-section .section-heading { color: white; }
  .mission-card {
    background: linear-gradient(135deg, rgba(124,58,237,0.25), rgba(239,68,68,0.25));
    border: 3px solid #a855f7;
    border-radius: 24px;
    padding: 2rem;
    max-width: 580px;
    margin: 0 auto 2rem;
  }
  .mission-card p {
    font-size: clamp(1rem, 3.5vw, 1.3rem);
    font-weight: 800;
    line-height: 1.7;
  }
  .watch-btn {
    display: inline-block;
    background: linear-gradient(135deg, #7c3aed, #ef4444);
    color: white;
    font-family: 'Bangers', cursive;
    font-size: 1.75rem;
    letter-spacing: 0.1em;
    padding: 0.875rem 2.5rem;
    border-radius: 60px;
    text-decoration: none;
    box-shadow: 0 0 24px rgba(168,85,247,0.4), 0 8px 24px rgba(0,0,0,0.3);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .watch-btn:hover {
    transform: scale(1.05) translateY(-3px);
    box-shadow: 0 0 40px rgba(168,85,247,0.7), 0 12px 32px rgba(0,0,0,0.3);
    text-decoration: none;
  }

  /* HIGHLIGHT HELPERS */
  .highlight-purple { color: #a855f7; }
  .highlight-red { color: #ff6b6b; }
  .highlight-cyan { color: #67e8f9; }
  .highlight-gold { color: #fbbf24; }

  @media (max-width: 600px) {
    .steps-grid { grid-template-columns: 1fr; }
    .powers-grid { grid-template-columns: 1fr; }
  }
</style>

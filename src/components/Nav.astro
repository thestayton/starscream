---
import { site } from '../../site.config.js';
const currentPath = Astro.url.pathname;
---

<header class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">{site.name}</a>
    <nav class="nav-links" aria-label="Main navigation">
      <ul>
        {site.nav.map((item) => (
          <li>
            <a
              href={item.href}
              class={currentPath === item.href ? 'active' : ''}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    {site.navCta && (
      <a href={site.navCta.href} class="btn-nav-cta" target="_blank" rel="noopener">
        {site.navCta.label}
      </a>
    )}
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 26, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(168, 85, 247, 0.25);
  }
  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    height: 60px;
    gap: 1.5rem;
  }
  .nav-logo {
    font-family: 'Bangers', cursive;
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    background: linear-gradient(135deg, #a855f7, #ef4444);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
    margin-right: auto;
  }
  .nav-links ul {
    list-style: none;
    display: flex;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
  }
  .nav-links a {
    display: block;
    padding: 0.375rem 0.75rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 800;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: #fff;
    background: rgba(168, 85, 247, 0.15);
    text-decoration: none;
  }
  .btn-nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1.1rem;
    border-radius: 50px;
    background: linear-gradient(135deg, #7c3aed, #ef4444);
    color: white;
    font-size: 0.875rem;
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 0 16px rgba(168, 85, 247, 0.35);
  }
  .btn-nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 24px rgba(168, 85, 247, 0.6);
    text-decoration: none;
  }
  @media (max-width: 600px) {
    .nav-links { display: none; }
  }
</style>
